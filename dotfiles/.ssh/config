Host github.com
  AddKeysToAgent yes
  IdentitiesOnly no
  ForwardX11 yes

# Optional dedicated GitHub key:
# Host github.com
#   IdentityFile ~/.ssh/github_noreply

Host *
  ControlMaster auto
  ControlPath ~/.ssh/control/%h_%p_%r
  ControlPersist 10m

# Optional personal host aliases:
# Host proxmox
#   HostName 192.168.1.9
#   User root
#   Port 22
#   IdentityFile ~/.ssh/id_rsa

# Optional on machines with Colima installed.
# Include ~/.colima/ssh_config
