Host github.com
  AddKeysToAgent yes
  IdentityFile ~/.ssh/github_noreply
  ForwardX11 yes

Host *
  ControlMaster auto
  ControlPath ~/.ssh/control/%h_%p_%r
  ControlPersist 10m

